# Application
NODE_ENV=development
PORT=4000

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://crmanaliz:PLACEHOLDER_PASSWORD@localhost:5432/crmanaliz
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crmanaliz
DATABASE_USER=crmanaliz
DATABASE_PASSWORD=PLACEHOLDER_PASSWORD

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=PLACEHOLDER_PASSWORD

# JWT & Authentication
JWT_ACCESS_SECRET=PLACEHOLDER_JWT_ACCESS_SECRET_MIN_32_CHARS_CHANGE_IN_PRODUCTION
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=PLACEHOLDER_JWT_REFRESH_SECRET_MIN_32_CHARS_CHANGE_IN_PRODUCTION
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for sensitive data like API keys)
ENCRYPTION_KEY=PLACEHOLDER_ENCRYPTION_KEY_MIN_32_CHARS_CHANGE_IN_PRODUCTION

# Bootstrap Admin User (for initial setup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=PLACEHOLDER_CHANGE_IMMEDIATELY

# ISSmanager Integration Defaults
ISSMANAGER_DEFAULT_TIMEOUT_MS=30000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_SWAGGER=false
ENABLE_METRICS=true

# App URL (for emails, links etc)
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
