# Application
NODE_ENV=development
PORT=4000

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://crmanaliz:PLACEHOLDER_PASSWORD@localhost:5432/crmanaliz
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crmanaliz
DATABASE_USER=crmanaliz
DATABASE_PASSWORD=PLACEHOLDER_PASSWORD

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=PLACEHOLDER_PASSWORD

# ISSmanager Integration
ISSMANAGER_API_URL=https://PLACEHOLDER_URL/api
ISSMANAGER_API_KEY=PLACEHOLDER_API_KEY
ISSMANAGER_SYNC_INTERVAL_MINUTES=60

# JWT & Authentication
JWT_SECRET=PLACEHOLDER_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=PLACEHOLDER_REFRESH_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRATION=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_METRICS=true
