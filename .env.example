# ─────────────────────────────────────────────────────────────────────────────
# crmanaliz — environment template
# Copy to `.env.local` (gitignored) and fill in real values for development.
# Production secrets should live in your secret manager, not on disk.
# ─────────────────────────────────────────────────────────────────────────────

# ── ISS Manager v2 API ──────────────────────────────────────────────────────
# Base URL exposes /iss/v2/* read endpoints.
ISSMANAGER_BASE_URL=http://192.168.106.118/api

# Created via http://192.168.106.118/api-sistem/v2/ekle
# Format: iss_v2_<16char>
ISSMANAGER_CLIENT_ID=

# Shown once on creation; if lost, regenerate the client.
ISSMANAGER_CLIENT_SECRET=

# Network tuning (optional). Defaults below match production guardrails.
ISSMANAGER_TIMEOUT_MS=30000
ISSMANAGER_MAX_RETRY=3

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Production must use sslmode=require and a managed certificate.
DATABASE_URL=postgres://crmanaliz:secret@localhost:5432/crmanaliz?sslmode=disable

# ── PII column-level encryption ─────────────────────────────────────────────
# 32-byte (64 hex char) key used for AES-256-GCM column encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_MASTER_KEY=

# ── Session HMAC signing (M5) ───────────────────────────────────────────────
# 32-byte (64 hex char) key used for cookie session sign/verify.
# MUST be different from PII_MASTER_KEY — config validation rejects reuse.
# Rotate independently of PII_MASTER_KEY.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_KEY=

# ── Logger ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
