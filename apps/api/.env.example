# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/crmanaliz

# Encryption (minimum 32 characters)
ENCRYPTION_KEY=your-32-char-minimum-encryption-key-change-in-production

# JWT Secrets (minimum 32 characters)
JWT_ACCESS_SECRET=your-32-char-minimum-jwt-access-secret-change-in-production
JWT_REFRESH_SECRET=your-32-char-minimum-jwt-refresh-secret-change-in-production

# JWT Expiration Times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development

# Default Admin User (for seed script)
# IMPORTANT: These are the credentials created by `pnpm prisma db seed`
# Login with: admin@bullvar.com / admin OR admin / admin (username shortcut)
DEFAULT_ADMIN_EMAIL=admin@bullvar.com
DEFAULT_ADMIN_PASSWORD=admin
