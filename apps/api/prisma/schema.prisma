// CRM Analiz Platform - Prisma Schema
// Database: PostgreSQL
// ORM: Prisma 7+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  ANALYST
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  name         String?
  role         Role    @default(ANALYST)
  isActive     Boolean @default(true) @map("is_active")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Relations
  sessions             UserSession[]
  auditLogs            AuditLog[]
  createdIntegrations  IntegrationConfig[] @relation("CreatedIntegrations")
  updatedIntegrations  IntegrationConfig[] @relation("UpdatedIntegrations")
  createdImportBatches ImportBatch[]       @relation("CreatedImportBatches")

  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ============================================
// AUDIT LOGGING
// ============================================

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  INTEGRATION_CREATED
  INTEGRATION_UPDATED
  INTEGRATION_DELETED
  INTEGRATION_TESTED
  SYNC_STARTED
  SYNC_COMPLETED
  SYNC_FAILED
  CONFIG_CHANGED
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String?     @map("entity_type")
  entityId   String?     @map("entity_id")
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// INTEGRATION CONFIGURATION
// ============================================

enum IntegrationProvider {
  ISSMANAGER
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  INACTIVE
  ERROR
}

model IntegrationConfig {
  id              String              @id @default(cuid())
  provider        IntegrationProvider @default(ISSMANAGER)
  name            String
  baseUrl         String              @map("base_url")
  apiKeyEncrypted String              @map("api_key_encrypted") // Encrypted, never plain
  timeoutMs       Int                 @default(30000) @map("timeout_ms")
  isEnabled       Boolean             @default(true) @map("is_enabled")
  status          IntegrationStatus   @default(PENDING)

  lastTestAt      DateTime? @map("last_test_at")
  lastTestStatus  String?   @map("last_test_status")
  lastTestMessage String?   @map("last_test_message")
  lastSyncAt      DateTime? @map("last_sync_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  updatedById String?  @map("updated_by_id")

  // Relations
  createdBy User                 @relation("CreatedIntegrations", fields: [createdById], references: [id])
  updatedBy User?                @relation("UpdatedIntegrations", fields: [updatedById], references: [id])
  syncRuns  IntegrationSyncRun[]

  @@index([provider])
  @@index([isEnabled])
  @@map("integration_configs")
}

// ============================================
// SYNC RUNS & STATES
// ============================================

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model IntegrationSyncRun {
  id                  String     @id @default(cuid())
  integrationConfigId String     @map("integration_config_id")
  status              SyncStatus @default(PENDING)
  startedAt           DateTime   @default(now()) @map("started_at")
  completedAt         DateTime?  @map("completed_at")

  recordsProcessed Int @default(0) @map("records_processed")
  recordsSucceeded Int @default(0) @map("records_succeeded")
  recordsFailed    Int @default(0) @map("records_failed")

  errorMessage String? @map("error_message")
  metadata     Json?

  // Relations
  integrationConfig IntegrationConfig @relation(fields: [integrationConfigId], references: [id], onDelete: Cascade)

  @@index([integrationConfigId])
  @@index([status])
  @@index([startedAt])
  @@map("integration_sync_runs")
}

// ============================================
// GEOGRAPHIC DATA
// ============================================

model Neighborhood {
  id         String  @id @default(cuid())
  name       String
  district   String
  city       String
  postalCode String? @map("postal_code")

  // Quality scoring fields
  qualityScore          Float?    @map("quality_score")
  qualityScoreUpdatedAt DateTime? @map("quality_score_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customers CustomerSnapshot[]

  @@unique([name, district, city])
  @@index([city, district])
  @@index([qualityScore])
  @@map("neighborhoods")
}

// ============================================
// CUSTOMER SNAPSHOTS (Shadow Records from ISSmanager)
// ============================================

model CustomerSnapshot {
  id             String  @id @default(cuid())
  externalId     String  @map("external_id") // External system customer ID
  neighborhoodId String? @map("neighborhood_id")

  name    String?
  email   String?
  phone   String?
  address String?

  // Source tracking
  sourceType    String? @map("source_type") // "ISSMANAGER_API", "CSV_UPLOAD", etc.
  sourceBatchId String? @map("source_batch_id") // Import batch reference

  // Source-specific raw data (flexible, source-agnostic)
  sourceData Json? @map("source_data")

  snapshotAt DateTime @default(now()) @map("snapshot_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([neighborhoodId])
  @@index([snapshotAt])
  @@index([sourceBatchId])
  @@map("customer_snapshots")
}

// ============================================
// PERSONNEL SNAPSHOTS
// ============================================

model PersonnelSnapshot {
  id         String @id @default(cuid())
  externalId String @map("external_id") // External system personnel ID

  name  String?
  email String?
  phone String?
  role  String?

  // Performance metrics (to be expanded)
  performanceScore Float? @map("performance_score")

  // Source tracking
  sourceType    String? @map("source_type")
  sourceBatchId String? @map("source_batch_id")

  // Source-specific raw data
  sourceData Json? @map("source_data")

  snapshotAt DateTime @default(now()) @map("snapshot_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([snapshotAt])
  @@index([sourceBatchId])
  @@map("personnel_snapshots")
}

// ============================================
// FINANCE SNAPSHOTS
// ============================================

model FinanceSnapshot {
  id         String @id @default(cuid())
  externalId String @map("external_id") // External system finance record ID

  transactionType String?   @map("transaction_type")
  amount          Float?
  currency        String?   @default("TRY")
  date            DateTime?

  // Source tracking
  sourceType    String? @map("source_type")
  sourceBatchId String? @map("source_batch_id")

  // Source-specific raw data
  sourceData Json? @map("source_data")

  snapshotAt DateTime @default(now()) @map("snapshot_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([date])
  @@index([snapshotAt])
  @@index([sourceBatchId])
  @@map("finance_snapshots")
}

// ============================================
// DATA IMPORT TRACKING
// ============================================

enum ImportSourceType {
  CSV_UPLOAD
  EXCEL_UPLOAD
  ISSMANAGER_API
  ISSMANAGER_EXPORT
  DATABASE_EXPORT
  MANUAL_ENTRY
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIALLY_COMPLETED
}

enum ImportEntityType {
  CUSTOMER
  PERSONNEL
  FINANCE
  NEIGHBORHOOD
}

model ImportBatch {
  id         String           @id @default(cuid())
  sourceType ImportSourceType @map("source_type")
  entityType ImportEntityType @map("entity_type")
  status     ImportStatus     @default(PENDING)

  // File metadata (if applicable)
  fileName     String? @map("file_name")
  fileSize     Int?    @map("file_size")
  fileMimeType String? @map("file_mime_type")

  // Import statistics
  totalRows   Int @default(0) @map("total_rows")
  successRows Int @default(0) @map("success_rows")
  failedRows  Int @default(0) @map("failed_rows")
  skippedRows Int @default(0) @map("skipped_rows")

  // Execution metadata
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")

  // User tracking
  createdByUserId String @map("created_by_user_id")
  createdBy       User   @relation("CreatedImportBatches", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  errors ImportError[]
  jobs   ImportJob[]

  @@index([status])
  @@index([entityType])
  @@index([createdByUserId])
  @@index([createdAt])
  @@map("import_batches")
}

model ImportJob {
  id      String      @id @default(cuid())
  batchId String      @map("batch_id")
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rowNumber Int          @map("row_number")
  status    ImportStatus @default(PENDING)

  // Source data (raw)
  rawData Json @map("raw_data")

  // Normalized data (if successful)
  normalizedData Json? @map("normalized_data")

  // Processing metadata
  processedAt  DateTime? @map("processed_at")
  errorMessage String?   @map("error_message")

  // Result tracking
  resultEntityId String? @map("result_entity_id") // ID of created/updated snapshot
  resultAction   String? @map("result_action") // "created", "updated", "skipped"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId])
  @@index([status])
  @@index([rowNumber])
  @@map("import_jobs")
}

model ImportError {
  id      String      @id @default(cuid())
  batchId String      @map("batch_id")
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rowNumber    Int?   @map("row_number")
  errorType    String @map("error_type") // "validation", "parsing", "duplicate", "constraint"
  errorMessage String @map("error_message")
  errorDetails Json?  @map("error_details")

  // Field-level error tracking
  fieldName  String? @map("field_name")
  fieldValue String? @map("field_value")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([batchId])
  @@index([errorType])
  @@map("import_errors")
}
