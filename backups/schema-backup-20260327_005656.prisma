// CRM Analiz Platform - Prisma Schema
// Database: PostgreSQL
// ORM: Prisma 7+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  ANALYST
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  role         Role      @default(ANALYST)
  isActive     Boolean   @default(true) @map("is_active")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  // Relations
  sessions            UserSession[]
  auditLogs           AuditLog[]
  createdIntegrations IntegrationConfig[] @relation("CreatedIntegrations")
  updatedIntegrations IntegrationConfig[] @relation("UpdatedIntegrations")

  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")

  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ============================================
// AUDIT LOGGING
// ============================================

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  INTEGRATION_CREATED
  INTEGRATION_UPDATED
  INTEGRATION_DELETED
  INTEGRATION_TESTED
  SYNC_STARTED
  SYNC_COMPLETED
  SYNC_FAILED
  CONFIG_CHANGED
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String?     @map("entity_type")
  entityId   String?     @map("entity_id")
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")

  createdAt  DateTime    @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// INTEGRATION CONFIGURATION
// ============================================

enum IntegrationProvider {
  ISSMANAGER
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  INACTIVE
  ERROR
}

model IntegrationConfig {
  id              String              @id @default(cuid())
  provider        IntegrationProvider @default(ISSMANAGER)
  name            String
  baseUrl         String              @map("base_url")
  apiKeyEncrypted String              @map("api_key_encrypted") // Encrypted, never plain
  timeoutMs       Int                 @default(30000) @map("timeout_ms")
  isEnabled       Boolean             @default(true) @map("is_enabled")
  status          IntegrationStatus   @default(PENDING)

  lastTestAt      DateTime?           @map("last_test_at")
  lastTestStatus  String?             @map("last_test_status")
  lastTestMessage String?             @map("last_test_message")
  lastSyncAt      DateTime?           @map("last_sync_at")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  createdById     String              @map("created_by_id")
  updatedById     String?             @map("updated_by_id")

  // Relations
  createdBy User                @relation("CreatedIntegrations", fields: [createdById], references: [id])
  updatedBy User?               @relation("UpdatedIntegrations", fields: [updatedById], references: [id])
  syncRuns  IntegrationSyncRun[]

  @@index([provider])
  @@index([isEnabled])
  @@map("integration_configs")
}

// ============================================
// SYNC RUNS & STATES
// ============================================

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model IntegrationSyncRun {
  id                 String        @id @default(cuid())
  integrationConfigId String       @map("integration_config_id")
  status             SyncStatus    @default(PENDING)
  startedAt          DateTime      @default(now()) @map("started_at")
  completedAt        DateTime?     @map("completed_at")

  recordsProcessed   Int           @default(0) @map("records_processed")
  recordsSucceeded   Int           @default(0) @map("records_succeeded")
  recordsFailed      Int           @default(0) @map("records_failed")

  errorMessage       String?       @map("error_message")
  metadata           Json?

  // Relations
  integrationConfig IntegrationConfig @relation(fields: [integrationConfigId], references: [id], onDelete: Cascade)

  @@index([integrationConfigId])
  @@index([status])
  @@index([startedAt])
  @@map("integration_sync_runs")
}

// ============================================
// GEOGRAPHIC DATA
// ============================================

model Neighborhood {
  id          String   @id @default(cuid())
  name        String
  district    String
  city        String
  postalCode  String?  @map("postal_code")

  // Quality scoring fields
  qualityScore       Float?   @map("quality_score")
  qualityScoreUpdatedAt DateTime? @map("quality_score_updated_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customers CustomerSnapshot[]

  @@unique([name, district, city])
  @@index([city, district])
  @@index([qualityScore])
  @@map("neighborhoods")
}

// ============================================
// CUSTOMER SNAPSHOTS (Shadow Records from ISSmanager)
// ============================================

model CustomerSnapshot {
  id                 String    @id @default(cuid())
  externalId         String    @map("external_id") // ISSmanager customer ID
  neighborhoodId     String?   @map("neighborhood_id")

  name               String?
  email              String?
  phone              String?
  address            String?

  // ISSmanager specific fields (flexible, can expand)
  issmanagerData     Json?     @map("issmanager_data")

  snapshotAt         DateTime  @default(now()) @map("snapshot_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([neighborhoodId])
  @@index([snapshotAt])
  @@map("customer_snapshots")
}

// ============================================
// PERSONNEL SNAPSHOTS
// ============================================

model PersonnelSnapshot {
  id                 String    @id @default(cuid())
  externalId         String    @map("external_id") // ISSmanager personnel ID

  name               String?
  email              String?
  phone              String?
  role               String?

  // Performance metrics (to be expanded)
  performanceScore   Float?    @map("performance_score")

  // ISSmanager specific fields
  issmanagerData     Json?     @map("issmanager_data")

  snapshotAt         DateTime  @default(now()) @map("snapshot_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([snapshotAt])
  @@map("personnel_snapshots")
}

// ============================================
// FINANCE SNAPSHOTS
// ============================================

model FinanceSnapshot {
  id                 String    @id @default(cuid())
  externalId         String    @map("external_id") // ISSmanager finance record ID

  transactionType    String?   @map("transaction_type")
  amount             Float?
  currency           String?   @default("TRY")
  date               DateTime?

  // ISSmanager specific fields
  issmanagerData     Json?     @map("issmanager_data")

  snapshotAt         DateTime  @default(now()) @map("snapshot_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([externalId, snapshotAt])
  @@index([externalId])
  @@index([date])
  @@index([snapshotAt])
  @@map("finance_snapshots")
}
